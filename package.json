{
  "name": "myshell",
  "version": "0.1.0",
  "description": "A lightweight Xshell-like SSH terminal built with Electron and xterm.js",
  "author": "zhangfeiyang",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently -k \"npm:dev\" \"npm:electron\"",
    "build:web": "vite build",
    "build": "npm run build:web",
    "pack": "npm run build:web && electron-builder --dir",
    "dist:win": "npm run build:web && electron-builder --win nsis"
  },
  "dependencies": {
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "@xterm/addon-fit": "^0.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^36.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.zhangfeiyang.myshell",
    "productName": "MyShell",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
