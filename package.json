{
  "name": "myshell",
  "version": "0.1.0",
  "description": "A lightweight Xshell-like SSH terminal built with Electron and xterm.js",
  "author": "zhangfeiyang",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently -k \"npm:dev\" \"npm:electron\"",
    "build:web": "vite build",
    "build:assets": "python3 scripts/generate_release_assets.py",
    "build": "npm run build:web",
    "pack": "npm run build:assets && npm run build:web && electron-builder --dir",
    "dist:win": "npm run build:assets && npm run build:web && electron-builder --win nsis portable",
    "release:check": "node scripts/check-release.mjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^36.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.zhangfeiyang.myshell",
    "productName": "MyShell",
    "asar": true,
    "compression": "maximum",
    "executableName": "MyShell",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "buildResources/icon.ico",
      "publisherName": "zhangfeiyang",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MyShell",
      "uninstallDisplayName": "MyShell",
      "installerIcon": "buildResources/icon.ico",
      "uninstallerIcon": "buildResources/icon.ico",
      "installerHeaderIcon": "buildResources/icon.ico",
      "installerSidebar": "buildResources/installerSidebar.bmp",
      "uninstallerSidebar": "buildResources/uninstallerSidebar.bmp",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    }
  }
}
